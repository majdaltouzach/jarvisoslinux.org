---
import BaseLayout from "../layouts/BaseLayout.astro";

const buildScripts = [
  { num: "00", title: "Install Prerequisites", desc: "Cross-distro installer for all build tools (Arch, Fedora, Debian, openSUSE). Validates arch-chroot, squashfs-tools, xorriso, p7zip, Rust/Cargo, and QEMU before proceeding." },
  { num: "01", title: "Extract ISO", desc: "Uses 7z to unpack the CachyOS desktop ISO, relocates the EFI boot image, and records the source UUID for the final rebuild." },
  { num: "02", title: "Unsquash Filesystem", desc: "Decompresses airootfs.sfs into a writable rootfs, cleans stale mounts, validates critical directories, and prepares chroot mount points." },
  { num: "03", title: "Bake Wayland", desc: "Installs KDE Plasma 6 on Wayland into the extracted rootfs via chroot." },
  { num: "03b", title: "Build Kernel", desc: "Compiles the custom linux-jarvisos kernel (6.19-stable) with the /dev/jarvis character device and associated kernel subsystems. Parallel build via nproc." },
  { num: "04", title: "Bake JARVIS", desc: "Integrates the full AI stack into the rootfs: Ollama, Project-JARVIS (Python + venv), dmcp and dispatch Rust binaries, systemd services, and the first-boot interactive setup script." },
  { num: "05", title: "Bake Calamares", desc: "Deploys the graphical installer configuration package into the rootfs for guided hardware installation." },
  { num: "06", title: "Squash Filesystem", desc: "Recompresses the modified rootfs back into a SquashFS image (airootfs.sfs)." },
  { num: "07", title: "Rebuild ISO", desc: "Assembles the final bootable ISO from the modified filesystem, EFI image, and boot configuration. Supports both BIOS and UEFI boot." },
];
---

<BaseLayout
  title="Docs"
  description="Getting started with JARVIS OS — build system walkthrough, setup instructions, and architecture reference."
>
  <section class="section">
    <div class="container">
      <span class="section-label">Documentation</span>
      <h1 class="section-title">Docs</h1>
      <p class="docs-intro">
        Everything you need to understand, build, and run JARVIS OS. This documentation
        covers the build pipeline, system architecture, and getting started instructions.
      </p>
    </div>
  </section>

  <!-- Quick start -->
  <section class="section" style="padding-top: 0;">
    <div class="container">
      <h2 style="margin-bottom: var(--space-xl);">Quick Start</h2>
      <div class="grid-2">
        <div class="card">
          <h3>Option A: Download ISO</h3>
          <p>The fastest way to try JARVIS OS. Download the pre-built ISO, flash it, and boot.</p>
          <pre class="mono code-block"><code># Flash to USB
sudo dd if=jarvisos-*.iso of=/dev/sdX bs=4M status=progress

# Or boot in QEMU
qemu-system-x86_64 -m 4G -smp 4 -cdrom jarvisos-*.iso</code></pre>
          <a href="/download" class="btn btn-outline" style="margin-top: var(--space-lg);">
            Download page &rarr;
          </a>
        </div>
        <div class="card">
          <h3>Option B: Build from Source</h3>
          <p>Clone the repo with submodules and run the build pipeline. Requires an <strong>Arch-based host</strong> (uses pacman/makepkg).</p>
          <pre class="mono code-block"><code>git clone --recurse-submodules \
  https://github.com/YakupAtahanov/jarvisos.git
cd jarvisos/scripts

# Install build prerequisites first
sudo bash 00-install-prereq.sh

# Then build with Makefile
make all</code></pre>
          <a
            href="https://github.com/YakupAtahanov/jarvisos"
            class="btn btn-outline"
            style="margin-top: var(--space-lg);"
            target="_blank"
            rel="noopener noreferrer"
          >
            View source &nearr;
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Build pipeline -->
  <section class="section">
    <div class="container">
      <span class="section-label">Build System</span>
      <h2 style="margin-bottom: var(--space-xl);">The Build Pipeline</h2>
      <p style="margin-bottom: var(--space-2xl);">
        JARVIS OS is built through a sequence of modular scripts (00 through 07, plus a
        kernel build step 03b). Each script handles one stage and can be audited independently.
        All scripts live in the <code>scripts/</code> directory and are orchestrated by a Makefile.
      </p>
      <div class="pipeline">
        {buildScripts.map((s) => (
          <div class="pipeline-step card">
            <div class="pipeline-num mono">{s.num}</div>
            <div class="pipeline-content">
              <h3>{s.title}</h3>
              <p>{s.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Using jarvis CLI -->
  <section class="section">
    <div class="container">
      <span class="section-label">Usage</span>
      <h2 style="margin-bottom: var(--space-xl);">The <code>jarvis</code> CLI</h2>
      <div class="card">
        <p style="margin-bottom: var(--space-lg);">
          Once booted into JARVIS OS, interact with the AI through the <code>jarvis</code>
          command. The agent communicates with the custom kernel via <code>/dev/jarvis</code>,
          connects to the local Ollama instance, and dispatches actions through the MCP layer
          according to the four-tier security policy (SAFE → ELEVATED → DANGEROUS → FORBIDDEN).
        </p>
        <pre class="mono code-block"><code># Start a session
jarvis

# The AI can now:
# - Create, modify, and delete system tools via MCP
# - Execute commands with configured privilege levels
# - Maintain conversational context across interactions</code></pre>
        <p class="mono text-muted" style="margin-top: var(--space-lg); font-size: 0.8rem;">
          See <a href="https://github.com/YakupAtahanov/Project-JARVIS" target="_blank" rel="noopener noreferrer">Project-JARVIS</a> for full documentation.
        </p>
      </div>
    </div>
  </section>

  <!-- System requirements -->
  <section class="section">
    <div class="container">
      <span class="section-label">Requirements</span>
      <h2 style="margin-bottom: var(--space-xl);">System Requirements</h2>
      <div class="grid-2">
        <div class="card">
          <h3>Minimum</h3>
          <ul class="req-list">
            <li><span class="mono text-muted">CPU</span> x86_64 processor</li>
            <li><span class="mono text-muted">RAM</span> 4 GB</li>
            <li><span class="mono text-muted">Disk</span> 20 GB</li>
            <li><span class="mono text-muted">GPU</span> Not required (CPU inference)</li>
          </ul>
        </div>
        <div class="card">
          <h3>Recommended</h3>
          <ul class="req-list">
            <li><span class="mono text-muted">CPU</span> 8+ core modern processor</li>
            <li><span class="mono text-muted">RAM</span> 16 GB+</li>
            <li><span class="mono text-muted">Disk</span> 50 GB+ SSD</li>
            <li><span class="mono text-muted">GPU</span> NVIDIA (for accelerated inference)</li>
          </ul>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .docs-intro {
    font-size: 1.05rem;
    max-width: 640px;
  }

  .code-block {
    margin-top: var(--space-md);
    padding: var(--space-md);
    background: var(--bg-primary);
    border: 1px solid var(--border);
    border-radius: 4px;
    font-size: 0.8rem;
    overflow-x: auto;
    line-height: 1.6;
  }

  .pipeline {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .pipeline-step {
    display: flex;
    align-items: flex-start;
    gap: var(--space-xl);
    border-radius: 0;
  }

  .pipeline-step:first-child {
    border-radius: 6px 6px 0 0;
  }

  .pipeline-step:last-child {
    border-radius: 0 0 6px 6px;
  }

  .pipeline-num {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--cyan);
    min-width: 2.5rem;
    line-height: 1;
    padding-top: 0.1em;
  }

  .pipeline-content h3 {
    font-size: 1rem;
    margin-bottom: var(--space-xs);
  }

  .pipeline-content p {
    font-size: 0.85rem;
  }

  .req-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    margin-top: var(--space-md);
  }

  .req-list li {
    display: flex;
    gap: var(--space-md);
    font-size: 0.9rem;
  }

  .req-list .mono {
    min-width: 3rem;
    font-size: 0.75rem;
    text-transform: uppercase;
  }
</style>
