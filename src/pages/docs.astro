---
import BaseLayout from "../layouts/BaseLayout.astro";

const buildScripts = [
  { num: "01", title: "Base System", desc: "Bootstrap the base Arch Linux system with essential packages and configuration." },
  { num: "02", title: "User Setup", desc: "Create user accounts, set permissions, and configure sudo policies." },
  { num: "03", title: "Desktop Environment", desc: "Install and configure KDE Plasma 6 with Wayland session defaults." },
  { num: "04", title: "AI Stack", desc: "Install Ollama, configure local LLM inference, and set up model defaults." },
  { num: "05", title: "Jarvis Core", desc: "Deploy the jarvis-core daemon, CLI tools, and session management." },
  { num: "06", title: "MCP Integration", desc: "Set up the MCP server registry, tool permissions, and orchestration layer." },
  { num: "07", title: "ISO Packaging", desc: "Package everything into a bootable ISO with Calamares installer." },
];
---

<BaseLayout
  title="Docs"
  description="Getting started with JARVIS OS — build system walkthrough, setup instructions, and architecture reference."
>
  <section class="section">
    <div class="container">
      <span class="section-label">Documentation</span>
      <h1 class="section-title">Docs</h1>
      <p class="docs-intro">
        Everything you need to understand, build, and run JARVIS OS. This documentation
        covers the build pipeline, system architecture, and getting started instructions.
      </p>
    </div>
  </section>

  <!-- Quick start -->
  <section class="section" style="padding-top: 0;">
    <div class="container">
      <h2 style="margin-bottom: var(--space-xl);">Quick Start</h2>
      <div class="grid-2">
        <div class="card">
          <h3>Option A: Download ISO</h3>
          <p>The fastest way to try JARVIS OS. Download the pre-built ISO, flash it, and boot.</p>
          <pre class="mono code-block"><code># Flash to USB
sudo dd if=jarvisos-*.iso of=/dev/sdX bs=4M status=progress

# Or boot in QEMU
qemu-system-x86_64 -m 4G -smp 4 -cdrom jarvisos-*.iso</code></pre>
          <a href="/download" class="btn btn-outline" style="margin-top: var(--space-lg);">
            Download page &rarr;
          </a>
        </div>
        <div class="card">
          <h3>Option B: Build from Source</h3>
          <p>Clone the repo and run the full seven-script build pipeline on an Arch Linux host.</p>
          <pre class="mono code-block"><code>git clone https://github.com/jarvisos/jarvisos.git
cd jarvisos

# Run each build stage sequentially
sudo ./01-base-system.sh
sudo ./02-user-setup.sh
# ... through 07</code></pre>
          <a
            href="https://github.com/jarvisos/jarvisos"
            class="btn btn-outline"
            style="margin-top: var(--space-lg);"
            target="_blank"
            rel="noopener noreferrer"
          >
            View source &nearr;
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Build pipeline -->
  <section class="section">
    <div class="container">
      <span class="section-label">Build System</span>
      <h2 style="margin-bottom: var(--space-xl);">The Seven-Script Pipeline</h2>
      <p style="margin-bottom: var(--space-2xl);">
        JARVIS OS is built through a sequence of seven modular scripts. Each script handles
        one stage of the build and can be audited independently.
      </p>
      <div class="pipeline">
        {buildScripts.map((s) => (
          <div class="pipeline-step card">
            <div class="pipeline-num mono">{s.num}</div>
            <div class="pipeline-content">
              <h3>{s.title}</h3>
              <p>{s.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Using jarvis CLI -->
  <section class="section">
    <div class="container">
      <span class="section-label">Usage</span>
      <h2 style="margin-bottom: var(--space-xl);">The <code>jarvis</code> CLI</h2>
      <div class="card">
        <p style="margin-bottom: var(--space-lg);">
          Once booted into JARVIS OS, interact with the AI through the <code>jarvis</code>
          command. The daemon connects to the local Ollama instance and has access to MCP
          tools based on your configured permissions.
        </p>
        <pre class="mono code-block"><code># Start a session
jarvis

# The AI can now:
# - Create, modify, and delete system tools via MCP
# - Execute commands with configured privilege levels
# - Maintain conversational context across interactions</code></pre>
        <p class="mono text-muted" style="margin-top: var(--space-lg); font-size: 0.8rem;">
          See <a href="https://github.com/jarvisos/jarvis-core" target="_blank" rel="noopener noreferrer">jarvis-core</a> for full CLI documentation.
        </p>
      </div>
    </div>
  </section>

  <!-- System requirements -->
  <section class="section">
    <div class="container">
      <span class="section-label">Requirements</span>
      <h2 style="margin-bottom: var(--space-xl);">System Requirements</h2>
      <div class="grid-2">
        <div class="card">
          <h3>Minimum</h3>
          <ul class="req-list">
            <li><span class="mono text-muted">CPU</span> x86_64 processor</li>
            <li><span class="mono text-muted">RAM</span> 4 GB</li>
            <li><span class="mono text-muted">Disk</span> 20 GB</li>
            <li><span class="mono text-muted">GPU</span> Not required (CPU inference)</li>
          </ul>
        </div>
        <div class="card">
          <h3>Recommended</h3>
          <ul class="req-list">
            <li><span class="mono text-muted">CPU</span> 8+ core modern processor</li>
            <li><span class="mono text-muted">RAM</span> 16 GB+</li>
            <li><span class="mono text-muted">Disk</span> 50 GB+ SSD</li>
            <li><span class="mono text-muted">GPU</span> NVIDIA (for accelerated inference)</li>
          </ul>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .docs-intro {
    font-size: 1.05rem;
    max-width: 640px;
  }

  .code-block {
    margin-top: var(--space-md);
    padding: var(--space-md);
    background: var(--bg-primary);
    border: 1px solid var(--border);
    border-radius: 4px;
    font-size: 0.8rem;
    overflow-x: auto;
    line-height: 1.6;
  }

  .pipeline {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .pipeline-step {
    display: flex;
    align-items: flex-start;
    gap: var(--space-xl);
    border-radius: 0;
  }

  .pipeline-step:first-child {
    border-radius: 6px 6px 0 0;
  }

  .pipeline-step:last-child {
    border-radius: 0 0 6px 6px;
  }

  .pipeline-num {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--cyan);
    min-width: 2.5rem;
    line-height: 1;
    padding-top: 0.1em;
  }

  .pipeline-content h3 {
    font-size: 1rem;
    margin-bottom: var(--space-xs);
  }

  .pipeline-content p {
    font-size: 0.85rem;
  }

  .req-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    margin-top: var(--space-md);
  }

  .req-list li {
    display: flex;
    gap: var(--space-md);
    font-size: 0.9rem;
  }

  .req-list .mono {
    min-width: 3rem;
    font-size: 0.75rem;
    text-transform: uppercase;
  }
</style>
